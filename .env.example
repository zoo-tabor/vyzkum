# ------------------------------------------------------------------
# CRM vyzkum plemen psu - vzorovy .env
# Zkopirujte do .env a doplnte skutecne hodnoty: cp .env.example .env
# Soubor .env je v .gitignore a NESMI byt commitnut.
# ------------------------------------------------------------------

APP_ENV=local
APP_DEBUG=true
APP_URL=https://vyzkum.zootabor.eu
APP_KEY=
ASSET_BASE_PATH=

# Databaze (MariaDB/MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vyzkum
DB_USERNAME=
DB_PASSWORD=

# E-mail - SMTP (odchozi posta vyzkum@zootabor.eu)
SMTP_HOST=linux.ekospol.cz
SMTP_PORT=
SMTP_USER=zoo_vyzkum
SMTP_PASS=
SMTP_FROM=vyzkum@zootabor.eu
SMTP_FROM_NAME="Vyzkum Zoo Tabor"
SMTP_USE_STARTTLS=true

# E-mail - IMAP (ulozeni odeslane posty / nacitani odpovedi)
IMAP_HOST=linux.ekospol.cz
IMAP_PORT=143
IMAP_USE_STARTTLS=true
IMAP_SENT_FOLDER=Sent
IMAP_SAVE_TO_SENT=true

# Mail prepinac (false = e-maily se jen loguji, neodesilaji)
MAIL_ENABLED=false

# Transport: mail = PHP mail() (wedos, odchozi SMTP 25 je blokovan) | smtp = primy SMTP
MAIL_TRANSPORT=mail

# Vynucene 2FA pro research_admin (false = vypnuto, vhodne behem vyvoje)
ENFORCE_ADMIN_2FA=true
