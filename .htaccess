Options -Indexes
DirectoryIndex public/index.php

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  RewriteRule ^(?:app|database|docs|scripts|storage)(?:/|$) - [F,L]
  RewriteRule ^(?:\.env|\.env\.example|README\.md|composer\.(?:json|lock))$ - [F,L]

  RewriteRule ^assets/(.*)$ public/assets/$1 [L]
  RewriteRule ^manifest\.webmanifest$ public/manifest.webmanifest [L]
  RewriteRule ^sw\.js$ public/sw.js [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ public/index.php [QSA,L]
</IfModule>

<FilesMatch "^\.">
  Require all denied
</FilesMatch>
